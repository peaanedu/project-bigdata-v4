PROJECT_NAME=hadoop_v2_prod
TZ=Asia/Phnom_Penh
HADOOP_VERSION=3.4.1
HIVE_VERSION=4.0.1
SPARK_VERSION=3.5.2
POSTGRES_VERSION=16
CLUSTER_NAME=bigdata-lab-v2
HDFS_REPLICATION=2
CORE_CONF_fs_defaultFS=hdfs://namenode:8020
YARN_CONF_yarn_resourcemanager_hostname=resourcemanager
YARN_CONF_yarn_log___aggregation___enable=true
YARN_CONF_yarn_nodemanager_aux___services=mapreduce_shuffle
MAPRED_CONF_mapreduce_framework_name=yarn
MAPRED_CONF_mapreduce_map_memory_mb=512
MAPRED_CONF_mapreduce_reduce_memory_mb=512
MAPRED_CONF_mapreduce_map_java_opts=-Xmx384m
MAPRED_CONF_mapreduce_reduce_java_opts=-Xmx384m
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_replication=2
HDFS_CONF_dfs_permissions_enabled=false
HDFS_CONF_dfs_webhdfs_enabled=true
HDFS_CONF_dfs_namenode_name_dir=file:///hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=file:///hadoop/dfs/data
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive123
JUPYTER_TOKEN=bigdata123
